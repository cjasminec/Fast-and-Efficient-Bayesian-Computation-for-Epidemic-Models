#how do we do incidence?
add.loglike_epi <- function(theta, y, deltat, x0){
  N <- length(y)
  inc <- 1/deltat
  output <- eulerSIR(x0, exp(c(theta[1],theta[2])), deltat, N-1)
  index <- 1+(0:(N-1))*inc
  output <- output[index, 2]
  loglikeindiv <- dnorm(y, output, exp(theta[3]), log=TRUE)
  loglike <- sum(loglikeindiv)
  return (loglike)
}

add.loglikeseir <- function(theta, y, deltat, x0){
  N <- length(y)
  inc <- 1/deltat 
  output <- eulerSEIR(x0, exp(c(theta[1],theta[2], theta[3])), deltat, N-1)
  output <- output[1+(0:(N-1))*inc, 3]
  loglike <- sum(dnorm(y, output, exp(theta[4]), log=TRUE))
  return (loglike)
}

